              </div>
              <div style="text-align:right">
                <div style="font-size:11px;font-weight:800;color:#F57C00">Kurang Rp 80.000</div>
              </div>
            </div>
            <div class="progress-container">
              <div class="progress-bg"><div class="progress-fill" style="width:92%"></div></div>
            </div>
          </div>

          <div class="store-card">
            <div class="store-top">
              <div class="store-ic warn">🏪</div>
              <div class="store-info">
                <h5>UD Cahaya Terang</h5>
                <p style="color:var(--gray4);font-weight:700">Rp 850.000</p>
              </div>
              <div style="text-align:right">
                <div style="font-size:11px;font-weight:800;color:#F57C00">Kurang Rp 150.000</div>
              </div>
            </div>
            <div class="progress-container">
              <div class="progress-bg"><div class="progress-fill" style="width:85%"></div></div>
            </div>
          </div>
        </div>

        <div id="cont-lb" style="flex:1;overflow-y:auto;padding-bottom:100px;display:none">
          <div
            style="padding:12px 16px;background:#fff;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--gray1)">
            <select
              style="background:var(--gray1);border:none;padding:8px 12px;border-radius:10px;font-size:11px;font-weight:700;outline:none">
              <option>📅 April 2026</option>
              <option>📅 Maret 2026</option>
            </select>
            <button style="color:var(--blue);font-size:12px;font-weight:800;background:none;border:none;cursor:pointer"
              onclick="openPrize()">🎁 Info Hadiah</button>
          </div>
          
          <div class="podium">
            <!-- Rank 2 -->
            <div class="pod-item">
              <div class="pod-icon">🥈</div>
              <div class="pod-name">Budi S.</div>
              <div class="pod-ta">45 TA</div>
              <div class="pod-base b2">2</div>
            </div>
            <!-- Rank 1 -->
            <div class="pod-item">
              <div class="pod-icon" style="font-size:36px;margin-bottom:0">👑</div>
              <div class="pod-name" style="font-size:14px">Ahmad R.</div>
              <div class="pod-ta">52 TA</div>
              <div class="pod-base b1">1</div>
            </div>
            <!-- Rank 3 -->
            <div class="pod-item">
              <div class="pod-icon">🥉</div>
              <div class="pod-name">Siti R.</div>
              <div class="pod-ta">41 TA</div>
              <div class="pod-base b3">3</div>
            </div>
          </div>

          <div id="lb-dynamic-list" style="margin-top:10px"></div>
        </div>
      </div>
    </div>

    <!-- PRIZE MODAL -->
    <div class="modal-overlay" id="prize-modal">
      <div class="modal">
        <div class="modal-header">DAFTAR PENERIMA HADIAH</div>
        <div class="modal-body">
          <table class="prize-table">
            <tr style="background:#f9f9f9;text-align:left">
              <th>RANK</th>
              <th>NAMA</th>
              <th>HADIAH</th>
            </tr>
            <tr>
              <td><b>1</b></td>
              <td>Ahmad R.</td>
              <td>Trip Bali (All-in)</td>
            </tr>
            <tr>
              <td><b>2</b></td>
              <td>Budi S.</td>
              <td>Voucher Belanja Rp 1jt</td>
            </tr>
            <tr>
              <td><b>...</b></td>
              <td>...</td>
              <td>...</td>
            </tr>
          </table>
          <button class="close-modal" onclick="closePrize()">Tutup</button>
        </div>
      </div>
    </div>
  </div>

  <!-- EXTERNAL CONTROLS (v6) -->
  <div class="controls">
    <h3>Skenario Case</h3>
    <button class="sw-btn active" onclick="setCase('star4', event)"><b>#31 (Star 4)</b><br>Lihat Top 20% + Kamu + 3
      Bawah</button>
    <button class="sw-btn" onclick="setCase('star5', event)"><b>#15 (Star 5)</b><br>Lihat Full Daftar Star 5
      (1-25)</button>
    <button class="sw-btn" onclick="setCase('star1', event)"><b>#112 (Star 1)</b><br>Peringatan Penalti TA < 15</button>
        <button class="sw-btn" onclick="setCase('done', event)"><b>STATUS SELESAI</b><br>Tampilan periode
          berakhir</button>
        <div style="height:10px"></div>
        <button class="sw-btn" style="background:rgba(255,255,255,.15)" onclick="goToHome()">🏠 Ke Beranda
          Utama</button>
  </div>

  <script>
    const scenarios = {
      star4: { ta: 22, rank: 31, star: 4, label: 'STATUS: BERJALAN', alert: { type: 'warn', text: 'Tambah 3 TA lagi untuk reward penuh Star 4' } },
      star5: { ta: 32, rank: 15, star: 5, label: 'STATUS: BERJALAN', alert: null },
      star1: { ta: 12, rank: 112, star: 1, label: 'STATUS: BERJALAN', alert: { type: 'danger', text: '⚠️ Terancam penalti (TA < 15). Kejar 3 TA lagi!' } },
      done: { ta: 28, rank: 24, star: 4, label: 'STATUS: SELESAI', alert: null }
    };
    let currentCase = 'star4';
    function goToDashboard() { document.getElementById('s-home').classList.remove('active'); document.getElementById('s-dashboard').classList.add('active'); }
    function goToHome() { document.getElementById('s-dashboard').classList.remove('active'); document.getElementById('s-home').classList.add('active'); }
    function switchTab(t) {
      document.getElementById('t-toko-btn').classList.toggle('active', t === 'toko');
      document.getElementById('tab-lb-btn').classList.toggle('active', t === 'lb');
      document.getElementById('cont-toko').style.display = t === 'toko' ? 'block' : 'none';
      document.getElementById('cont-lb').style.display = t === 'lb' ? 'block' : 'none';
      if (t === 'lb') renderLeaderboard();
    }
    function setCase(k, e) {
      currentCase = k; const c = scenarios[k];
      document.querySelectorAll('.controls .sw-btn').forEach(b => b.classList.remove('active'));
      if (e) e.currentTarget.classList.add('active');
      document.getElementById('dash-rank-pill').innerText = `Star ${c.star} · #${c.rank} dari 127`;
      document.getElementById('status-label').innerText = c.label;
      document.getElementById('m-ta').innerText = c.ta;
      document.getElementById('m-rank').innerText = '#' + c.rank;
      const dStars = document.getElementById('dash-stars');
      dStars.innerHTML = '';
      for (let i = 1; i <= 5; i++) dStars.innerHTML += '<span style="font-size:24px;' + (i > c.star ? 'filter:grayscale(1);opacity:.3' : '') + '">⭐</span>';
      const alertArea = document.getElementById('alert-area');
      alertArea.innerHTML = '';
      if (c.alert) alertArea.innerHTML = `<div class="alert-bar ${c.alert.type}"><span>${c.alert.type === 'warn' ? '⚠️' : '🚫'}</span><p>${c.alert.text}</p></div>`;
      renderLeaderboard(); goToDashboard();
    }
    function renderLeaderboard() {
      const list = document.getElementById('lb-dynamic-list'); list.innerHTML = '';
      const names = ["Doni Prabowo", "Rina Oktavia", "Eko Prasetyo", "Maya Sari", "Andi Wijaya"];
      const myRank = scenarios[currentCase].rank; const top20 = 25;
      for (let i = 4; i <= top20; i++) {
        const n = names[i % 5] + " " + i;
        list.innerHTML += createLBItem(i, n, 38 - Math.floor(i/2), 5, (i === myRank));
      }
      if (myRank > top20) {
        list.innerHTML += `<div style="text-align:center;padding:12px;color:var(--gray3);letter-spacing:6px">···</div>`;
        list.innerHTML += createLBItem(myRank, `Afif Choirul (Kamu)`, scenarios[currentCase].ta, scenarios[currentCase].star, true);
        for (let i = 1; i <= 3; i++) if (myRank + i <= 127) list.innerHTML += createLBItem(myRank + i, `Sales CR ${myRank + i}`, scenarios[currentCase].ta - i, 4, false);
      }
    }
    function createLBItem(rank, name, ta, star, isMe) {
      return `<div class="lb-item ${isMe ? 'me' : ''}">
      <div class="lb-rank">#${rank}</div>
      <div class="lb-info">
        <h5>${name}</h5>
        <p>${ta} TA</p>
      </div>
      <div class="star-tag">⭐ Star ${star}</div>
    </div>`;
    }
    function openPrize() { document.getElementById('prize-modal').style.display = 'flex'; }
    function closePrize() { document.getElementById('prize-modal').style.display = 'none'; }
    setCase('star4');
  </script>
</body>

</html>
