<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
  <title>Star Sales BNN — Final Premium Prototype</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* CSS ASLI v1 - JANGAN DIUBAH DASARNYA */
    :root {
      --navy: #0D2461;
      --blue: #1565C0;
      --blue2: #1E88E5;
      --gold: #FFB300;
      --ok: #4CAF50;
      --warn: #FF9800;
      --danger: #F44336;
      --bg: #F0F4F8;
      --white: #fff;
      --gray1: #F5F5F5;
      --gray2: #E0E0E0;
      --gray3: #9E9E9E;
      --gray4: #424242
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
      font-family: 'Inter', sans-serif
    }

    body {
      background: linear-gradient(135deg, #0a1a4e, #1565C0, #0a1a4e);
      min-height: 100vh;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      padding: 20px;
      gap: 50px
    }

    /* PHONE FRAME v1 */
    .phone {
      width: 390px;
      height: 820px;
      background: var(--bg);
      border-radius: 40px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: 0 0 0 10px #111, 0 40px 80px rgba(0, 0, 0, .6);
      position: relative;
      flex-shrink: 0
    }

    .statusbar {
      background: var(--navy);
      color: #fff;
      display: flex;
      justify-content: space-between;
      padding: 10px 22px;
      font-size: 12px;
      font-weight: 600
    }

    .screens {
      flex: 1;
      overflow: hidden;
      position: relative
    }

    .screen {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow-y: auto;
      background: var(--bg);
      display: none;
      flex-direction: column
    }

    .screen.active {
      display: flex
    }

    /* HOME COMPONENTS v1 */
    .hdr {
      background: linear-gradient(180deg, #0D2461, #0f2d75);
      padding: 12px 16px
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 12px
    }

    .logo-ic {
      width: 30px;
      height: 30px;
      background: linear-gradient(135deg, #1E88E5, #0D2461);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 900;
      color: #fff
    }

    .pcard {
      background: rgba(255, 255, 255, .13);
      border-radius: 12px;
      padding: 12px;
      display: flex;
      align-items: flex-start;
      gap: 10px;
      color: #fff
    }

    .av {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: rgba(255, 255, 255, .25);
      border: 2px solid rgba(255, 255, 255, .4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px
    }

    .saldo-amt {
      color: #fff;
      font-size: 22px;
      font-weight: 800;
      margin-top: 2px
    }

    .ss-card {
      background: linear-gradient(135deg, #0D2461, #1565C0, #1E88E5);
      margin: 12px;
      border-radius: 16px;
      padding: 16px;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      box-shadow: 0 6px 20px rgba(21, 101, 192, .35);
      color: #fff
    }

    .ss-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: rgba(255, 255, 255, .2);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      padding: 3px 8px;
      border-radius: 10px;
      margin-bottom: 8px
    }

    .ss-stats {
      display: flex;
      gap: 12px;
      margin: 12px 0
    }

    .ss-stat {
      text-align: center;
      flex: 1
    }

    .ss-stat h4 {
      font-size: 18px;
      font-weight: 800
    }

    .ss-stat p {
      font-size: 10px;
      opacity: .7
    }

    .divv {
      width: 1px;
      background: rgba(255, 255, 255, .2);
      align-self: stretch
    }

    /* DASHBOARD HERO v1 BASED */
    .ss-hero {
      padding: 12px 16px 20px;
      background: linear-gradient(180deg, #1565C0, #0D2461 130%);
      color: #fff
    }

    .hero-top-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px
    }

    .back-btn {
      width: 32px;
      height: 32px;
      background: rgba(255, 255, 255, .15);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 16px;
      color: #fff;
      border: none
    }

    .hero-info-line {
      font-size: 11px;
      color: rgba(255, 255, 255, .75);
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 4px;
      font-weight: 500
    }

    .hero-rank-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px
    }

    .hero-stars-box {
      display: flex;
      gap: 3px
    }

    .hero-stars-box span {
      font-size: 24px
    }

    .hero-rank-pill {
      background: rgba(255, 255, 255, .15);
      border-radius: 20px;
      padding: 5px 12px;
      font-size: 11px;
      font-weight: 700;
      color: #fff;
      border: 1px solid rgba(255, 255, 255, .25)
    }

    /* GRID 4 KOLOM v1 BASED (Boxes Style) */
    .hero-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px
    }

    .hero-box {
      background: rgba(255, 255, 255, .13);
      border-radius: 14px;
      padding: 12px 4px;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 95px;
      backdrop-filter: blur(4px);
      border: 1px solid rgba(255, 255, 255, .05)
    }

    .hero-box .l-top {
      font-size: 9px;
      font-weight: 700;
      opacity: .65;
      margin-bottom: 4px;
      letter-spacing: .3px
    }

    .hero-box h4 {
      font-size: 22px;
      font-weight: 800;
      margin-bottom: 2px
    }

    .hero-box .l-bot {
      font-size: 10px;
      opacity: .6
    }

    /* ALERT v1 */
    .alert-bar {
      background: rgba(255, 140, 0, .15);
      border-top: 1px solid rgba(255, 140, 0, .3);
      padding: 10px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 600
    }

    .alert-bar.warn {
      color: #FFB74D
    }

    .alert-bar.danger {
      background: rgba(244, 67, 54, .12);
      border-top-color: rgba(244, 67, 54, .3);
      color: #FF8A80
    }

    /* TABS v1 */
    .tabs {
      display: flex;
      background: var(--white);
      border-bottom: 2px solid var(--gray2);
      position: sticky;
      top: 0;
      z-index: 15
    }

    .tab {
      flex: 1;
      text-align: center;
      padding: 14px;
      font-size: 12px;
      font-weight: 600;
      color: var(--gray3);
      cursor: pointer;
      border-bottom: 2px solid transparent
    }

    .tab.active {
      color: var(--blue);
      border-bottom-color: var(--blue)
    }

    /* LEADERBOARD v1 STYLE */
    .podium {
      display: flex;
      justify-content: center;
      align-items: flex-end;
      gap: 6px;
      padding: 20px 14px 10px;
      background: linear-gradient(180deg, #0D2461, #1565C0)
    }

    .pod-av {
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 700;
      color: #fff;
      border: 3px solid rgba(255, 255, 255, .4);
      background: rgba(255, 255, 255, .2)
    }

    .pod-av.s1 {
      width: 56px;
      height: 56px;
      border-color: var(--gold)
    }

    .pod-base {
      border-radius: 10px 10px 0 0;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 18px;
      color: #fff
    }

    .pod-base.b1 {
      height: 60px;
      background: rgba(255, 179, 0, .4);
      min-width: 90px
    }

    .pod-base.b2 {
      height: 44px;
      background: rgba(255, 255, 255, .2);
      min-width: 80px
    }

    .pod-base.b3 {
      height: 34px;
      background: rgba(255, 255, 255, .1);
      min-width: 70px
    }

    .lb-item {
      background: var(--white);
      margin: 0 10px 6px;
      border-radius: 12px;
      padding: 12px;
      display: flex;
      align-items: center;
      gap: 10px;
      box-shadow: 0 1px 4px rgba(0, 0, 0, .06)
    }

    .lb-item.me {
      background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
      border: 2px solid var(--blue2)
    }

    .lb-rank {
      width: 28px;
      text-align: center;
      font-size: 14px;
      font-weight: 800;
      color: var(--gray3)
    }

    .lb-name {
      font-size: 12px;
      font-weight: 700;
      color: var(--gray4)
    }

    .lb-star-tag {
      font-size: 10px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 4px
    }

    .s5-tag {
      background: #FFF8E1;
      color: #F57F17
    }

    .s4-tag {
      background: #E8EAF6;
      color: #283593
    }

    /* EXTERNAL CONTROLS (Clean Style) */
    .controls {
      width: 320px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      background: rgba(255, 255, 255, .05);
      padding: 25px;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, .1);
      backdrop-filter: blur(10px)
    }

    .controls h3 {
      color: #fff;
      font-size: 15px;
      margin-bottom: 8px;
      letter-spacing: 1px;
      text-transform: uppercase;
      opacity: .8
    }

    .sw-btn {
      background: rgba(255, 255, 255, .1);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, .1);
      padding: 14px;
      border-radius: 14px;
      font-size: 12px;
      cursor: pointer;
      text-align: left;
      transition: all .3s
    }

    .sw-btn:hover {
      background: rgba(255, 255, 255, .2)
    }

    .sw-btn.active {
      background: var(--blue);
      border-color: var(--blue2);
      box-shadow: 0 4px 12px rgba(21, 101, 192, .4)
    }

    /* MODAL */
    .modal-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, .8);
      z-index: 100;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px
    }

    .modal {
      background: #fff;
      border-radius: 28px;
      width: 100%;
      max-width: 350px;
      overflow: hidden;
      animation: pop .3s cubic-bezier(.17, .67, .83, .67)
    }

    .modal-header {
      padding: 20px;
      background: var(--navy);
      color: #fff;
      text-align: center;
      font-weight: 800
    }

    .modal-body {
      padding: 20px
    }

    .prize-table {
      width: 100%;
      border-collapse: collapse
    }

    .prize-table td,
    .prize-table th {
      padding: 12px 8px;
      font-size: 12px;
      border-bottom: 1px solid #f0f0f0
    }

    .close-modal {
      width: 100%;
      background: var(--blue);
      color: #fff;
      border: none;
      padding: 14px;
      border-radius: 14px;
      margin-top: 15px;
      font-weight: 800;
      cursor: pointer
    }
  /* STORE TAB STYLES (RESTORED) */
    .search-row { padding: 12px 14px; background: var(--bg) }
    .search-box { background: var(--white); border-radius: 14px; padding: 12px 16px; display: flex; align-items: center; gap: 10px; box-shadow: 0 1px 4px rgba(0, 0, 0, .05) }
    .search-box input { border: none; outline: none; font-size: 13px; width: 100%; color: var(--gray4); background: transparent }
    .store-card { background: var(--white); margin: 0 12px 10px; border-radius: 18px; padding: 14px; position: relative; box-shadow: 0 1px 6px rgba(0, 0, 0, .05); display: flex; flex-direction: column; gap: 10px }
    .store-top { display: flex; align-items: center; gap: 12px }
    .store-ic { width: 40px; height: 40px; background: #E8F5E9; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px }
    .store-ic.warn { background: #FFF3E0 }
    .store-info { flex: 1 }
    .store-info h5 { font-size: 14px; font-weight: 800; color: var(--gray4) }
    .store-info p { font-size: 11px; color: var(--gray3) }
    .status-flag { background: #E8F5E9; color: #2E7D32; font-size: 10px; font-weight: 800; padding: 2px 6px; border-radius: 6px; display: flex; align-items: center; gap: 4px }
    .status-flag.active-flag { border: 1px solid #C8E6C9 }
    .amt-text { font-size: 12px; font-weight: 700; color: var(--gray3); text-align: right }
    .progress-container { margin-top: 4px }
    .progress-bg { height: 6px; background: var(--gray1); border-radius: 10px; overflow: hidden }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #FF9800, #F57C00); border-radius: 10px }
    .show-more { text-align: center; padding: 10px; color: var(--blue); font-size: 12px; font-weight: 800; cursor: pointer }

    /* LEADERBOARD REFINEMENT (CLEAN) */
    .podium { display: flex; justify-content: center; align-items: flex-end; gap: 12px; padding: 35px 14px 15px; background: linear-gradient(180deg, #0D2461, #1565C0) }
    .pod-item { display: flex; flex-direction: column; align-items: center; text-align: center; width: 95px }
    .pod-icon { font-size: 28px; margin-bottom: 4px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2)) }
    .pod-name { font-size: 12px; font-weight: 800; color: #fff; margin-top: 5px }
    .pod-ta { font-size: 11px; color: rgba(255, 255, 255, .8); margin-bottom: 8px }
    .pod-base { border-radius: 10px 10px 0 0; width: 100%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 22px; color: rgba(255, 255, 255, .8) }
    .pod-base.b1 { height: 75px; background: rgba(255, 255, 255, .25); color: #fff }
    .pod-base.b2 { height: 55px; background: rgba(255, 255, 255, .15) }
    .pod-base.b3 { height: 45px; background: rgba(255, 255, 255, .1) }

    .lb-item { background: var(--white); margin: 0 12px 10px; border-radius: 18px; padding: 16px; display: flex; align-items: center; gap: 15px; box-shadow: 0 2px 8px rgba(0, 0, 0, .04) }
    .lb-rank { font-size: 18px; font-weight: 900; color: #FFB300; width: 35px }
    .lb-av-small { width: 42px; height: 42px; border-radius: 50%; background: #F5F5F5; display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--gray4) }
    .lb-info { flex: 1 }
    .lb-info h5 { font-size: 14px; font-weight: 800; color: var(--gray4); margin-bottom: 2px }
    .lb-info p { font-size: 12px; color: var(--gray3) }
    .star-tag { background: #FFF9E1; color: #FF8F00; font-size: 11px; font-weight: 800; padding: 4px 10px; border-radius: 12px; display: flex; align-items: center; gap: 4px; border: 1px solid #FFE082 }
  </style>
</head>

